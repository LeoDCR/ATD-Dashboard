[Unit]

Description=Dashboard Moto IoT

After=multi-user.target



[Service]

Type=simple

User=ubuntu

WorkingDirectory=/home/ubuntu/dashboard-iot

Environment="QT_QPA_PLATFORM=linuxfb"

# --- AQUÍ ESTÁ EL GUARDAESPALDAS MATA ZOMBIES ---

ExecStartPre=-/usr/bin/killall python3

# ------------------------------------------------

ExecStart=/home/ubuntu/dashboard-iot/venv/bin/python /home/ubuntu/dashboard-iot/main.py

Restart=always

RestartSec=3



[Install]

WantedBy=multi-user.target

